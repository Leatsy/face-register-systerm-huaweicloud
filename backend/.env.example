APP_NAME=Cloud Face Attendance API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api

# Comma-separated origins. Example:
# http://localhost:5173,http://127.0.0.1:5173,https://your-mobile-domain
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Replace this in production.
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=1440

# Local WSL development can use sqlite first.
# Huawei Cloud deployment should use RDS MySQL, for example:
# mysql+pymysql://<username>:<password>@<host>:3306/<database>?charset=utf8mb4
DATABASE_URL=sqlite:///./cloud_proj.db

# local or obs
STORAGE_BACKEND=local
LOCAL_UPLOAD_DIR=./uploads

# Public base URL of the backend service itself. Used when generating file access URLs.
# Local example:
PUBLIC_API_BASE_URL=http://127.0.0.1:8000
# Production example:
# PUBLIC_API_BASE_URL=https://api.example.com

# Huawei OBS settings. Enable when STORAGE_BACKEND=obs.
# Example OBS server: obs.cn-east-3.myhuaweicloud.com
OBS_BUCKET=
OBS_SERVER=
OBS_ACCESS_KEY_ID=
OBS_SECRET_ACCESS_KEY=
OBS_CDN_BASE_URL=
